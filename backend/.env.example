# Copy this file to .env and fill in your values

# Canvas LMS
CANVAS_BASE_URL=https://uta.instructure.com
CANVAS_CLIENT_ID=your_canvas_client_id
CANVAS_CLIENT_SECRET=your_canvas_client_secret

# For local dev — use your personal Canvas access token instead of OAuth
# Get it from: Canvas → Account → Settings → New Access Token
CANVAS_PERSONAL_TOKEN=your_personal_access_token_here

# Supabase (use SERVICE ROLE key here, not anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Anthropic (for announcement date parser)
# Get free API key at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

PORT=3001
